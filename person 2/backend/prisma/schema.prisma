datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Mock User Model (Since Person 1 hasn't built Auth yet, we need this for relationships)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role     @default(STUDENT)
  
  // Relations
  coursesTaught Course[]      @relation("FacultyCourses")
  enrollments   Enrollment[]
  submissions   Submission[]
  attendances   Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  FACULTY
  STUDENT
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  bannerImage String?
  
  // Faculty teaching this course
  facultyId   String
  faculty     User     @relation("FacultyCourses", fields: [facultyId], references: [id])
  
  modules     Module[]
  assignments Assignment[]
  enrollments Enrollment[]
  attendances Attendance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Junction table for Student Enrollment
model Enrollment {
  id        String @id @default(uuid())
  studentId String
  courseId  String
  
  student   User   @relation(fields: [studentId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  
  materials   Material[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Material {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String   // Local path or S3/Cloudinary URL
  fileType  String   // PDF, MP4, PPTX, etc.
  
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id])

  createdAt DateTime @default(now())
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  attachmentUrl String?
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])

  submissions Submission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Submission {
  id             String   @id @default(uuid())
  textSubmission String?
  fileUrl        String?
  grade          Float?
  feedback       String?
  
  studentId      String
  student        User     @relation(fields: [studentId], references: [id])
  
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, assignmentId])
}

model Attendance {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  status    AttendanceStatus
  
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, courseId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}
